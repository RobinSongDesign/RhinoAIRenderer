<Window x:Class="AIRenderer.Views.AIRenderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AIRenderer.Views"
        mc:Ignorable="d"
        Title="AI Render" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,10,0,8"/>
            <Setter Property="Foreground" Value="#333"/>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,5,0,2"/>
            <Setter Property="Foreground" Value="#555"/>
        </Style>
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style x:Key="InputStylePass" TargetType="PasswordBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style x:Key="ButtonPrimary" TargetType="Button">
            <Setter Property="Background" Value="#4A90D9"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A7BC8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#CCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ButtonSecondary" TargetType="Button">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#F0F0F0"/>
                                <Setter Property="Foreground" Value="#AAA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ButtonLightBlue" TargetType="Button">
            <Setter Property="Background" Value="#6BA5E7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5A94D6"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#CCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Main Content -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Image Preview -->
            <Grid Grid.Column="0" Margin="0,0,16,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Source Image -->
                <GroupBox Grid.Row="0" Header="Source Image" Margin="0,0,0,8">
                    <Border Background="#FAFAFA" BorderBrush="#DDD" BorderThickness="1">
                        <Grid>
                            <TextBlock Text="Click 'Capture View' to capture viewport"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#999"
                                       FontSize="14"
                                       Visibility="{Binding HasSourceImage, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                            <Image Source="{Binding SourceImage}" Stretch="Uniform" Margin="4"
                                   Visibility="{Binding HasSourceImage, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </Grid>
                    </Border>
                </GroupBox>

                <!-- Result Image -->
                <GroupBox Grid.Row="1" Header="Generated Result" Margin="0,8,0,0">
                    <Border Background="#FAFAFA" BorderBrush="#DDD" BorderThickness="1">
                        <Grid>
                            <TextBlock Text="Generated image will appear here"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#999"
                                       FontSize="14"
                                       Visibility="{Binding HasResultImage, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                            <Image Source="{Binding ResultImage}" Stretch="Uniform" Margin="4"
                                   Visibility="{Binding HasResultImage, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </Grid>
                    </Border>
                </GroupBox>
            </Grid>

            <!-- Right Panel - Settings -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                <StackPanel>
                    <!-- Header with Gear Icon -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="SETTINGS" Style="{StaticResource SectionHeaderStyle}"/>
                        <Button Grid.Column="1" x:Name="SettingsButton"
                                Click="SettingsButton_Click"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" ToolTip="Settings"
                                VerticalAlignment="Center" Margin="0,8,0,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" Padding="4">
                                        <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
                                              Fill="#666" Width="20" Height="20" Stretch="Uniform"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- Capture Section -->
                    <TextBlock Text="1. CAPTURE" Style="{StaticResource SectionHeaderStyle}"/>
                    <Button Content="Capture Active View" Command="{Binding CaptureCommand}"
                            Style="{StaticResource ButtonPrimary}" Margin="0,4,0,0"/>

                    <!-- Provider Info (Read-only display) -->
                    <TextBlock Text="2. SERVICE PROVIDER" Style="{StaticResource SectionHeaderStyle}"/>
                    <Border Background="#E8F4FD" BorderBrush="#B8D4E8" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock FontSize="12" Foreground="#333">
                                <Run Text="Provider: "/>
                                <Run Text="{Binding Settings.SelectedProviderDisplayName, Mode=OneWay}" FontWeight="SemiBold"/>
                            </TextBlock>
                            <TextBlock Text="Click gear icon above to configure API settings"
                                       FontSize="10" Foreground="#888" FontStyle="Italic" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Generation Parameters -->
                    <TextBlock Text="3. GENERATION PARAMETERS" Style="{StaticResource SectionHeaderStyle}"/>

                    <TextBlock Text="Model" Style="{StaticResource LabelStyle}"/>
                    <ComboBox ItemsSource="{Binding Settings.ModelList}"
                              SelectedItem="{Binding Settings.SelectedModelItem}"
                              DisplayMemberPath="DisplayName"
                              Padding="8,6"
                              FontSize="12"
                              Margin="0,0,0,8"/>

                    <!-- Style Template -->
                    <TextBlock Text="Style Template" Style="{StaticResource LabelStyle}"/>
                    <ComboBox ItemsSource="{Binding Settings.StyleTemplates}"
                              SelectedItem="{Binding Settings.SelectedStyle}"
                              DisplayMemberPath="Name"
                              Padding="8,6"
                              FontSize="12"
                              Margin="0,0,0,8"/>

                    <TextBlock Text="Prompt" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="PromptTextBox"
                             Text="{Binding Settings.Prompt, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputStyle}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             Height="60"
                             VerticalScrollBarVisibility="Auto"/>

                    <!-- Hidden System Prompt -->
                    <TextBox x:Name="SystemPromptTextBox"
                             Text="{Binding Settings.SystemPrompt, UpdateSourceTrigger=PropertyChanged}"
                             Visibility="Collapsed"/>

                    <!-- Aspect Ratio -->
                    <TextBlock Text="Aspect Ratio" Style="{StaticResource LabelStyle}"/>
                    <ComboBox ItemsSource="{Binding Settings.AspectRatios}"
                              SelectedItem="{Binding Settings.SelectedAspectRatio}"
                              DisplayMemberPath="Name"
                              Padding="8,6"
                              FontSize="12"
                              Margin="0,0,0,8"/>

                    <!-- Image Size -->
                    <TextBlock Text="Image Size" Style="{StaticResource LabelStyle}"/>
                    <ComboBox ItemsSource="{Binding Settings.ImageSizes}"
                              SelectedItem="{Binding Settings.SelectedImageSize}"
                              Padding="8,6"
                              FontSize="12"
                              Margin="0,0,0,8"/>

                    <!-- Generate Button -->
                    <Button Content="Generate Image" Command="{Binding GenerateCommand}"
                            Style="{StaticResource ButtonPrimary}"
                            Margin="0,20,0,8"/>

                    <!-- Save Result Button -->
                    <Button Content="Save Result" Command="{Binding SaveResultCommand}"
                            Style="{StaticResource ButtonLightBlue}"
                            Margin="0,0,0,8"/>

                    <!-- Action Buttons -->
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Content="Use as Source" Command="{Binding UseResultAsSourceCommand}"
                                Style="{StaticResource ButtonSecondary}" Margin="0,0,4,0"/>
                        <Button Grid.Column="1" Content="Clear All" Command="{Binding ClearCommand}"
                                Style="{StaticResource ButtonSecondary}" Margin="4,0,0,0"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Bottom Status Bar -->
        <Border Grid.Row="1" Background="#EEE" Padding="12,8" Margin="0,12,0,0" CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                           Foreground="#555" FontSize="12"/>
                <ProgressBar Grid.Column="1" IsIndeterminate="True" Width="100" Height="4"
                             Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
